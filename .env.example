# Copier vers .env et adapter. Toutes les variables sont préfixées par PULSE_.

# Connexion base de données (PostgreSQL en production).
PULSE_DATABASE_URL=postgresql+psycopg://pulse:pulse@localhost:5432/pulse

# Clé secrète pour signer les cookies de session. OBLIGATOIRE en production.
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
PULSE_SECRET_KEY=change-me-in-production

# Intervalle de collecte des flux, en minutes.
PULSE_FETCH_INTERVAL_MINUTES=30

# Timeout des requêtes HTTP vers les flux, en secondes.
PULSE_REQUEST_TIMEOUT=15

# Nombre de flux récupérés en parallèle.
PULSE_MAX_CONCURRENT_FETCHES=8

# --- Digest périodique par email (optionnel) ---
# Activer l'envoi automatique du digest.
PULSE_DIGEST_ENABLED=false
# Période couverte et heure d'envoi : "day" ou "week", heure 0-23.
PULSE_DIGEST_PERIOD=day
PULSE_DIGEST_HOUR=8
# Serveur SMTP.
PULSE_SMTP_HOST=
PULSE_SMTP_PORT=587
PULSE_SMTP_USER=
PULSE_SMTP_PASSWORD=
PULSE_SMTP_STARTTLS=true
# Expéditeur et destinataires (séparés par des virgules).
PULSE_DIGEST_FROM=
PULSE_DIGEST_TO=

# Mode debug (logs SQL, rechargement).
PULSE_DEBUG=false
